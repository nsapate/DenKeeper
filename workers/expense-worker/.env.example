DENKEEPER_EXPENSE_DB_PATH=/app/data/expenses.sqlite3
DENKEEPER_EXPENSE_TIMEZONE=America/Los_Angeles
DENKEEPER_EXPENSE_API_TOKEN=
# Secure default: require token auth when true.
DENKEEPER_EXPENSE_REQUIRE_API_TOKEN=true
