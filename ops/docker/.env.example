# Required secrets
OPENCLAW_GATEWAY_TOKEN=replace_with_strong_gateway_token
DENKEEPER_WORKER_TOKEN=replace_with_shared_worker_token

# Optional ports
OPENCLAW_GATEWAY_PORT=1455
DENKEEPER_WORKER_HOST_PORT=8765

# Optional auth bootstrap source (host path mounted read-only into OpenClaw container).
# Default resolves to project-root/.denkeeper-bootstrap.
OPENCLAW_BOOTSTRAP_HOST_DIR=../../.denkeeper-bootstrap

# Worker policy
DENKEEPER_EXPENSE_TIMEZONE=America/Los_Angeles
DENKEEPER_EXPENSE_ALLOWED_SCOPES=the-den
DENKEEPER_EXPENSE_REQUIRE_API_TOKEN=true

# Plugin defaults
DENKEEPER_DEFAULT_SCOPE=the-den
DENKEEPER_REQUEST_TIMEOUT_MS=5000

# Assistant/channel behavior
OPENCLAW_ASSISTANT_NAME=Kyoto
OPENCLAW_PRIMARY_MODEL=openai-codex/gpt-5.4
OPENCLAW_WHATSAPP_ENABLED=true
OPENCLAW_WHATSAPP_DM_POLICY=disabled
OPENCLAW_WHATSAPP_GROUP_POLICY=allowlist

# JSON values (must be valid JSON)
# Example: ["+10000000001","+10000000002"]
OPENCLAW_WHATSAPP_GROUP_ALLOW_FROM_JSON=[]
# Example: ["@?Kyoto","kyoto"]
OPENCLAW_GROUP_MENTION_PATTERNS_JSON=[]
# Example: {"120363406710798204@g.us":{"requireMention":true}}
OPENCLAW_WHATSAPP_GROUPS_JSON={}

# Optional healthcheck alert webhook
# DENKEEPER_ALERT_WEBHOOK_URL=https://example.com/webhook

# Healthcheck hardening
DENKEEPER_ENFORCE_MODEL_AUTH_HEALTH=true
DENKEEPER_AUTH_ERROR_LOOKBACK_MINUTES=15
# Optional: override OpenClaw auth error patterns for healthcheck
# DENKEEPER_MODEL_AUTH_ERROR_PATTERNS=OAuth token refresh failed|refresh_token_reused
